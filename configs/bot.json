{
  "project_root": "..",
  "chat": {
    "bot_name": "izu",
    "triggers": ["izukia", "izu", "ijok", "izo"],
    "hi_patterns": [
      "hi izu", "hello izu", "hey izu", "nihao izu",
      "hi izukia", "hello izukia", "hey izukia", "nihao izukia",
      "hi ijok", "hello ijok", "hey ijok", "nihao ijok"
    ],
    "startup_messages": [
      "Meow",
      "Chatbot is still experimental, will make mistake"
    ],
    "cooldown_seconds": 0.5,
    "user_cooldown_seconds": 0.5,
    "max_replies_per_minute": 10,
    "max_chat_chars": 248,
    "send_delay_seconds": 0,
    "ignore_after_send_seconds": 0.8,
    "max_input_chars": 800,
    "admin_names": [],
    "admin_only_commands": false,
    "blocked_substrings": ["voted yet!"]
  },
  "model": {
    "base_model": "TinyLlama/TinyLlama-1.1B-Chat-v1.0",
    "adapter_path": "artifacts/lora_full",
    "load_in_4bit": true,
    "torch_dtype": "auto",
    "device_map": "auto",
    "max_new_tokens": 96,
    "temperature": 0.35,
    "top_p": 0.9,
    "top_k": 50,
    "repetition_penalty": 1.12,
    "do_sample": true,
    "max_context_messages": 6
  },
  "retrieval": {
    "enabled": true,
    "index_dir": "artifacts/retriever",
    "embedding_model": "sentence-transformers/all-MiniLM-L6-v2",
    "top_k": 4,
    "min_score": 0.18,
    "max_context_chars": 1800
  },
  "logging": {
    "log_file": "artifacts/logs/autoreply.log",
    "log_level": "INFO"
  }
}
